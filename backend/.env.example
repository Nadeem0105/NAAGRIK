# Database Configuration
# Async URL is used by FastAPI (via asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/community_hero
# Sync URL is used by Alembic migrations (as Alembic runs synchronously)
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/community_hero

# JWT Security
JWT_SECRET_KEY=super-secret-jwt-signing-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Cloudinary Storage
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Groq AI
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=15

# Notifications (Resend Email Service)
RESEND_API_KEY=re_your_resend_api_key
NOTIFICATION_FROM_EMAIL=noreply@communityhero.app

# CORS Allowed Origins (Comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# App Settings
APP_ENV=development
